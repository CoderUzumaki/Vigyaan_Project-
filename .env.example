# ─────────────────────────────────────────────────────────────────────────────
# Environment Variables — Tourist Safety System
# Copy this to .env.local and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://admin:devpassword@127.0.0.1:5433/tourist_safety

# ── Redis (used by BullMQ for job queue + pub/sub) ───────────────────────────
REDIS_URL=redis://localhost:6379

# ── Hyperledger Fabric ───────────────────────────────────────────────────────
# Absolute path to fabric-samples on this machine.
# The worker reads TLS certs + identity from this directory.
FABRIC_SAMPLES_PATH=/tmp/fabric-samples

# Channel and chaincode (defaults shown — override only if different)
FABRIC_CHANNEL=safetychannel
FABRIC_CHAINCODE=safetychaincode

# Optional: override peer endpoints (defaults to localhost ports)
# ORG1_PEER_ENDPOINT=localhost:7051
# ORG2_PEER_ENDPOINT=localhost:9051
# ORG3_PEER_ENDPOINT=localhost:11051

# ── Worker ───────────────────────────────────────────────────────────────────
# Number of concurrent jobs the BullMQ worker can process
WORKER_CONCURRENCY=3

# ── JWT (for the backend API) ────────────────────────────────────────────────
JWT_SECRET=change_me_in_production_use_a_long_random_string

# ── File uploads (KYC) ───────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
